#include<stdio.h>
#include <string.h>
void reversal(char str[])
{
int size=strlen(str);
for (int i = 0; i < size/2; i++)
{
char temp = str[i];
str[i] = str[size - i - 1];
str[size - i - 1] = temp;
}
printf("reversed word:  %s", str);
}

  void encodeMessage(char str[]) {
    for (int i = 0; str[i] != '\0'; i++) {
        unsigned char ch = str[i];

        // Toggle 2nd and 5th bits (from right)
        ch = ch ^ (1 << 1); // toggle bit 2
        ch = ch ^ (1 << 4); // toggle bit 5

        str[i] = ch; // store back modified character
    }


  }
  void decode(char str[]){
    for (int i = 0; str[i] != '\0'; i++) {
        unsigned char ch = str[i];

        // Toggle 2nd and 5th bits (from right)
        ch = ch ^ (1 << 1); // toggle bit 2
        ch = ch ^ (1 << 4); // toggle bit 5

        str[i] = ch;}
        }




